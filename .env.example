# 研题库环境变量模板
# 复制为 .env 并填入真实值：cp .env.example .env

# JWT 密钥（必须修改）
JWT_ACCESS_SECRET=change-me-to-a-256-bit-random-key
JWT_REFRESH_SECRET=change-me-to-another-random-key

# MySQL
MYSQL_ROOT_PASS=yantiku_root_2026
MYSQL_USER=yantiku
MYSQL_PASS=yantiku_pass_2026

# RabbitMQ
RABBITMQ_USER=yantiku
RABBITMQ_PASS=yantiku_pass_2026
RABBITMQ_VHOST=yantiku

# Redis
REDIS_HOST=redis

# LLM（DeepSeek，可选，不填则回退为本地匹配）
LLM_API_KEY=sk-your-deepseek-api-key
